MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 83830493}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1677d487631066d4d89ee345f60c8ace, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::BookInteract
  readPanel: {fileID: 1319196914}
  bookText: {fileID: 735550908}
  nextButton: {fileID: 1225259694}
  prevButton: {fileID: 2047071686}
  closeButton: {fileID: 61832063}
  pages:
  - "Only silence remains. The old walls absorb the sounds of the past. They say
    that reality did not hold here \u2013 it cracked, warped, fell apart. Sometimes
    the changes are visible\u2026 sometimes not. You, who read these lines, are the
    next one who could watch the remnants of a world that is changing before your
    eyes.\r\n\r\nRemember \u2013 the more you miss, the less of you will remain."
  - 'Don''t be fooled by silence. Sometimes things only move when you''re not looking.



    Everything
    you see here has always been here. Just not always for you.'
